Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\SystemFileAssociations\.pdf\shell\ConvertToOCRv5]
@="Convert to OCR (v5)"
"Icon"="C:\\Windows\\System32\\imageres.dll,-5302"
"MultiSelectModel"="Document"      ; keeps menu visible for >15 items

[HKEY_CLASSES_ROOT\SystemFileAssociations\.pdf\shell\ConvertToOCRv5\command]
@="\"C:\\Utils\\pdfconvert\\run_pdfconvert_v5.bat\" \"%1\""
